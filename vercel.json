{
  "routes": [
    { "src": "^/$", "dest": "/landing.html" },
    { "src": "^/privacy$", "dest": "/privacy.html" },
    { "src": "^/terms$", "dest": "/terms.html" },
    { "src": "^/sitemap\\.xml$", "dest": "/sitemap.xml" },
    { "src": "^/robots\\.txt$", "dest": "/robots.txt" },
    { "src": "^/og-image\\.jpg$", "dest": "/og-image.jpg" },
    { "handle": "filesystem" },
    { "src": ".*", "dest": "/index.html" }
  ]
}
