{
  "name": "aruru-app",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "export:web": "expo export --platform web && node ./scripts/copy-landing-to-dist.cjs",
    "build": "npm run export:web",
    "verify:dist": "npm run build && git diff --exit-code HEAD -- dist",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "@expo-google-fonts/dm-mono": "^0.3.0",
    "@expo-google-fonts/dm-serif-display": "^0.3.0",
    "@expo-google-fonts/instrument-sans": "^0.3.0",
    "@expo/metro-runtime": "~3.2.3",
    "@react-native-async-storage/async-storage": "1.21.0",
    "@react-native-community/datetimepicker": "8.0.1",
    "@react-navigation/material-top-tabs": "^6.6.0",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "expo": "~51.0.0",
    "expo-font": "~12.0.0",
    "expo-image-picker": "~15.0.7",
    "expo-status-bar": "~1.12.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.1",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-svg": "15.2.0",
    "react-native-tab-view": "^3.5.2",
    "react-native-web": "~0.19.10"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~18.2.79",
    "@types/react-native": "~0.73.0",
    "typescript": "^5.3.0"
  }
}
